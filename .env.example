# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# App Configuration
APP_NAME=j88ks
APP_ENV=production
APP_DEBUG=false

# Expo Configuration
EXPO_PUBLIC_API_URL=https://api.example.com
EXPO_PUBLIC_WEB_URL=https://h12368.com

# EAS Configuration
EAS_PROJECT_ID=your-eas-project-id

# Build Configuration
# iOS Bundle Identifier (must match your provisioning profile)
IOS_BUNDLE_IDENTIFIER=com.j88ks.app

# Android Package Name
ANDROID_PACKAGE=com.j88ks.app

# API Keys (if needed)
# EXPO_PUBLIC_API_KEY=your-api-key-here
# EXPO_PUBLIC_ANALYTICS_ID=your-analytics-id

# Backend API (if you have one)
# API_BASE_URL=http://127.0.0.1:8082
# API_TIMEOUT=30000

# Feature Flags
# EXPO_PUBLIC_ENABLE_ANALYTICS=true
# EXPO_PUBLIC_ENABLE_NOTIFICATIONS=true

# Server Configuration (for deployment)
SERVER_IP=159.223.91.150
SERVER_USER=root
SERVER_PATH=/home/j88/public_html
DOMAIN=h12368.com

# Database (if needed)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=j88ks
# DB_USER=j88ksuser
# DB_PASSWORD=your-secure-password

# Redis (if needed)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# SSL/TLS
# SSL_ENABLED=true
# SSL_CERT_PATH=/www/server/panel/vhost/cert/h12368.com/fullchain.pem
# SSL_KEY_PATH=/www/server/panel/vhost/cert/h12368.com/privkey.pem

# Logging
LOG_LEVEL=info
LOG_PATH=/www/wwwlogs

# Security
# SECRET_KEY=your-secret-key-here
# JWT_SECRET=your-jwt-secret-here
# ENCRYPTION_KEY=your-encryption-key-here

# Third-party Services (if needed)
# SENTRY_DSN=your-sentry-dsn
# GOOGLE_ANALYTICS_ID=your-ga-id
# FIREBASE_CONFIG=your-firebase-config

# Development
# DEV_SERVER_PORT=8081
# DEV_TUNNEL=false
